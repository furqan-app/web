# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
app*
!app

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# generated prisma clients (build artifacts — run `npm run prisma-generate`)
/app/generated/

# local env files
.env*.local
# prod credentials for running prisma migrate resolve/status against prod DB from local machine
.env.prod
# docker compose runtime env (may hold credentials); templates *.example stay tracked
.env

# mcp config (contains secrets)
.mcp.json
.playwright-mcp

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# serwist service worker build output (generated from app/sw.ts)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js
/public/swe-worker-*.js.map

# local docs/plans

# retrospect skill output — never committed
/docs/retrospectives/

# Playwright transient output (baseline screenshots under e2e/tests/__screenshots__/
# are NOT ignored — those are committed on purpose, see docs/plans/visual-e2e-testing.md)
/playwright-report/
/test-results/

# claude local settings
settings.local.json
