# App environment — copy to .env.local and fill in real values:
#   cp .env.example .env.local
# Loaded by Next.js and by the npm scripts (via `dotenv -e .env.local`).
# .env.local is git-ignored; never commit real secrets.

# --- URLs ---
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# --- Auth ---
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-generated-secret"

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# --- Databases (match compose.yml defaults; app-db uses app_user on 3308) ---
QURAN_DATABASE_URL="mysql://quran_user:quran_password@localhost:3307/furqan_quran"
APP_DATABASE_URL="mysql://app_user:app_password@localhost:3308/furqan_app"

# --- Error tracking (Sentry) ---
# Leave NEXT_PUBLIC_SENTRY_DSN unset locally — the SDK no-ops without a DSN,
# which is what keeps dev silent. Real values are set only in Hostinger's
# build/runtime env panel, never committed here or in .env.production. See
# ADR 0017 (docs/architecture/adr/0017-sentry-error-tracking.md).
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# --- Sentry-to-Slack alert relay ---
# Sentry's native Slack alert action requires a paid plan; instead
# app/api/webhooks/sentry/route.ts relays triggered alert-rule webhooks to a
# Slack Incoming Webhook. Real values are Hostinger-panel-only, never
# committed. See ADR 0018 (docs/architecture/adr/0018-sentry-slack-relay-webhook.md).
SENTRY_WEBHOOK_SECRET=""
SLACK_WEBHOOK_URL=""
