# docker-compose overrides — OPTIONAL. Copy to .env only if you need to change
# the defaults; compose.yml already runs zero-config via inline ${VAR:-default}.
#   cp compose.env.example .env
# docker compose auto-loads .env for ${VAR} substitution. .env is git-ignored.
# Values below are the current defaults — copying as-is reproduces today's setup.

# --- quran-db (furqan_quran) ---
QURAN_DB_ROOT_PASSWORD=rootpassword
QURAN_DB_NAME=furqan_quran
QURAN_DB_USER=quran_user
QURAN_DB_PASSWORD=quran_password
QURAN_DB_PORT=3307

# --- app-db (furqan_app) ---
APP_DB_ROOT_PASSWORD=rootpassword
APP_DB_NAME=furqan_app
APP_DB_USER=app_user
APP_DB_PASSWORD=app_password
APP_DB_PORT=3308
