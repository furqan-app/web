{
  "name": "furqan",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy --schema prisma/app/schema.prisma && next build",
    "build:local": "dotenv -e .env.local -- npx prisma migrate deploy --schema prisma/app/schema.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "quran-studio": "dotenv -e .env.local -- npx prisma studio --schema prisma/quran/schema.prisma",
    "app-studio": "dotenv -e .env.local -- npx prisma studio --schema prisma/app/schema.prisma",
    "quran-generate": "dotenv -e .env.local -- npx prisma generate --schema prisma/quran/schema.prisma",
    "app-generate": "dotenv -e .env.local -- npx prisma generate --schema prisma/app/schema.prisma",
    "prisma-generate": "npm run quran-generate && npm run app-generate",
    "app-migrate-dev": "dotenv -e .env.local -- npx prisma migrate dev --schema prisma/app/schema.prisma",
    "quran-db-push": "dotenv -e .env.local -- npx prisma db push --schema prisma/quran/schema.prisma",
    "extract-translations": "node extract-translations.js",
    "seed:quran": "dotenv -e .env.local -- node scripts/quran-seed/seed.js",
    "postinstall": "prisma generate --schema prisma/quran/schema.prisma && prisma generate --schema prisma/app/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.21.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.64.0",
    "@serwist/next": "^9.5.11",
    "@tanstack/react-query": "^5.59.16",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.1",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "mysql2": "^3.11.3",
    "next": "14.2.15",
    "next-auth": "^4.24.10",
    "next-intl": "^3.25.1",
    "pino": "^10.3.1",
    "prisma": "^5.21.1",
    "react": "^18",
    "react-dom": "^18",
    "react-virtuoso": "^4.12.0",
    "serwist": "^9.5.11",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.26.2",
    "@babel/traverse": "^7.25.9",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-window": "^1.8.8",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.15",
    "fs-extra": "^11.2.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
