model Rub {
  id                  Int               @id @default(autoincrement())
  rub_number          Int               @unique
  verse_mapping_start Int
  verse_mapping_end   Int
  verses_count        Int
  rubVerseMappings    RubVerseMapping[] @relation("RubToRubVerseMapping")
  startVerse          Verse  @relation("StartVerse", fields: [verse_mapping_start], references: [id])
  endVerse            Verse  @relation("EndVerse", fields: [verse_mapping_end], references: [id])

  @@map("rubs")
}

model RubVerseMapping {
  id             Int  @id @default(autoincrement())
  rub_number     Int
  chapter_number Int
  start_verse    Int
  end_verse      Int
  rub            Rub  @relation("RubToRubVerseMapping", fields: [rub_number], references: [rub_number])

  @@map("rub_verse_mappings")
}

