generator client {
  provider = "prisma-client-js"
  output   = "../../app/generated/app-client"
}

datasource db {
  provider = "mysql"
  url      = env("APP_DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Mark {
  id          Int    @id @default(autoincrement())
  page_number Int
  from_user   Int
  to_user     Int
  marked_type String // verse, word
  marked_id   String // verse => verse_key , word => location
  category    String // memorization category key (see MARK_CATEGORIES)
  comment     String? @db.Text // optional free-text comment attached to the mark

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([marked_type, marked_id, to_user])
  @@map("marks")
}

// One-time share code a user generates to grant another user access to their
// mushaf. Spent (redeemed_at/redeemed_by set) on first successful redemption.
// Scalar user refs only — no relation to User (mirrors Mark; ADR 0008).
model MushafShareCode {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  owner_user  Int
  redeemed_at DateTime?
  redeemed_by Int?
  created_at  DateTime  @default(now())

  @@map("mushaf_share_codes")
}

// Persistent access grant: viewer_user may view/edit owner_user's mushaf marks.
// id is random (cuid) and used in the /mushaf/[grant] URL — it is NOT a
// capability; every grant-scoped endpoint re-checks viewer_user === self.
model MushafAccessGrant {
  id          String   @id @default(cuid())
  owner_user  Int
  viewer_user Int
  created_at  DateTime @default(now())

  @@unique([owner_user, viewer_user])
  @@map("mushaf_access_grants")
}

// Enrollment in a plan template (ADR 0028). template_key refers to the typed
// TS constants in app/constants/plans.ts — templates are code, not DB rows.
// Scalar user ref only (no relation — ADR 0008 pattern). params holds
// per-enrollment config (per-track quantities, start page, end date).
model UserPlan {
  id           Int      @id @default(autoincrement())
  user_id      Int
  template_key String
  params       Json
  start_date   DateTime @db.Date
  status       String   @default("active") // active | paused | completed | abandoned
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  progress     PlanProgressEntry[]

  @@index([user_id, status])
  @@map("user_plans")
}

// Append-only completion log. Daily assignments are DERIVED from this log +
// the template + enrollment params (never stored — ADR 0028). range_start/end
// are strings: page numbers today, wide enough for verse keys later. One
// check-off per (plan, track, day); re-checking updates the range in place.
model PlanProgressEntry {
  id           Int      @id @default(autoincrement())
  user_plan_id Int
  track_key    String
  date         DateTime @db.Date
  unit         String   @default("page")
  range_start  String
  range_end    String
  completed_at DateTime @default(now())
  userPlan     UserPlan @relation(fields: [user_plan_id], references: [id])

  @@unique([user_plan_id, track_key, date])
  @@map("plan_progress_entries")
}
